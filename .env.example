# ====================================================================
# Scholarship Management System — Environment Configuration
# ====================================================================
# Copy this file to .env and update with your actual values.
# WARNING: Never commit the .env file to version control.
# ====================================================================

# ====== Database Configuration ======
DB_URL=jdbc:mysql://mysql:3306/scholarship_portal?createDatabaseIfNotExist=true
DB_ROOT_PASSWORD=your-strong-root-password
DB_USERNAME=scholaruser
DB_PASSWORD=your-strong-db-password

# ====== JWT Configuration ======
# MUST be at least 32 characters (256 bits) for HS256
JWT_SECRET=your-secure-256-bit-secret-key-change-this-in-production-minimum-32-chars
JWT_EXPIRATION_MS=86400000

# ====== SMTP / Email Configuration ======
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=your-email@gmail.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ====== Redis Configuration ======
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ====== Kafka Configuration ======
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ====== Application Configuration ======
BACKEND_PORT=8080
FRONTEND_PORT=80
SPRING_PROFILES_ACTIVE=prod
CORS_ORIGINS=http://localhost:3000

# ====== Upload / Storage ======
UPLOAD_DIR=/app/uploads

# ====== Logging ======
LOG_FILE=/app/logs/scholarship-app.log

# ====== Frontend ======
REACT_APP_API_URL=http://localhost:8080
NODE_ENV=production
